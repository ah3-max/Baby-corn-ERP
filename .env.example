# =============================
# 資料庫設定
# =============================
POSTGRES_USER=babycorn
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=babycorn_erp
POSTGRES_HOST=db
POSTGRES_PORT=5432

# =============================
# 後端設定
# =============================
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================
# 前端設定
# =============================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================
# 上傳設定
# =============================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# =============================
# 環境設定
# =============================
# development | production
ENV=development

# CORS 允許的前端來源（多個用逗號分隔）
CORS_ORIGINS=http://localhost:3000

# =============================
# 備份設定
# =============================
# 本地備份保留天數（超過此天數的備份自動刪除）
BACKUP_KEEP_DAYS=7

# =============================
# 敏感欄位加密設定
# =============================
# Fernet 對稱加密金鑰（44 字元 base64url）
# 產生方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 留空表示不加密（開發環境可留空，正式環境必須設定）
ENCRYPTION_KEY=
